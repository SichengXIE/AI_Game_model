{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-game-mod-studio.local/schemas/asset-spec.schema.json",
  "title": "AI Game Mod Studio Asset Spec v0.1",
  "description": "Structured blueprint generated by AI and consumed by validators, package builders, and the CS2 Base Mod runtime.",
  "type": "object",
  "required": [
    "spec_version",
    "game",
    "asset_type",
    "title",
    "style",
    "footprint",
    "modules",
    "connections",
    "decor",
    "runtime_constraints"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "const": "0.1"
    },
    "game": {
      "type": "string",
      "const": "cities_skylines_2"
    },
    "asset_type": {
      "type": "string",
      "const": "train_station",
      "description": "Executable v0.1 only supports station-like assets. Use subtype for interchange or metro flavor."
    },
    "subtype": {
      "type": "string",
      "enum": ["small_station", "medium_station", "interchange_station", "metro_style_station", "regional_terminal"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "maxLength": 600
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "source_intent": {
      "$ref": "#/$defs/source_intent"
    },
    "style": {
      "$ref": "#/$defs/style"
    },
    "footprint": {
      "$ref": "#/$defs/footprint"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "$ref": "#/$defs/module"
      }
    },
    "connections": {
      "$ref": "#/$defs/connections"
    },
    "decor": {
      "$ref": "#/$defs/decor"
    },
    "preview_hints": {
      "$ref": "#/$defs/preview_hints"
    },
    "compatibility": {
      "$ref": "#/$defs/compatibility"
    },
    "runtime_constraints": {
      "$ref": "#/$defs/runtime_constraints"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "metadata": {
      "type": "object",
      "properties": {
        "asset_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{2,79}$"
        },
        "author": {
          "type": "string",
          "maxLength": 80
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "tags": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]{0,31}$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "source_intent": {
      "type": "object",
      "required": ["user_prompt", "design_priority"],
      "properties": {
        "user_prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        },
        "design_priority": {
          "type": "string",
          "enum": ["playable", "visual_fidelity", "compact_footprint", "high_capacity", "balanced"]
        },
        "must_have": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "style": {
      "type": "object",
      "required": ["theme", "regional_inspiration", "materials"],
      "properties": {
        "theme": {
          "type": "string",
          "enum": ["modern_transit", "civic_station", "industrial", "heritage", "airport_terminal", "minimal"]
        },
        "regional_inspiration": {
          "type": "string",
          "minLength": 1
        },
        "architectural_language": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string" }
        },
        "materials": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "enum": ["glass", "steel", "concrete", "aluminum", "stone", "brick", "wood", "green_roof", "painted_metal"]
          }
        },
        "lighting": {
          "type": "string",
          "enum": ["neutral", "warm", "cool", "bright_platforms", "night_accent"]
        },
        "reference_notes": {
          "type": "array",
          "maxItems": 8,
          "items": {
            "type": "string",
            "maxLength": 160
          }
        }
      },
      "additionalProperties": false
    },
    "footprint": {
      "type": "object",
      "required": ["width", "length", "height_class"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "unit": {
          "type": "string",
          "const": "meters"
        },
        "grid_size": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "height_class": {
          "type": "string",
          "enum": ["lowrise", "midrise", "tall_hall"]
        },
        "orientation": {
          "type": "string",
          "enum": ["track_parallel", "road_parallel", "corner_lot"]
        },
        "platform_length_class": {
          "type": "string",
          "enum": ["short", "medium", "long"]
        }
      },
      "additionalProperties": false
    },
    "module": {
      "type": "object",
      "required": ["module_id", "count"],
      "properties": {
        "module_id": {
          "type": "string",
          "enum": [
            "station.platform.island.small",
            "station.platform.island.medium",
            "station.platform.side.small",
            "station.concourse.basic",
            "station.concourse.glass_hall",
            "station.entrance.single",
            "station.entrance.corner",
            "station.decor.canopy",
            "station.decor.signage"
          ]
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "role": {
          "type": "string",
          "enum": ["platform", "concourse", "entrance", "decor", "service"]
        },
        "variant": {
          "type": "string",
          "maxLength": 80
        },
        "placement": {
          "$ref": "#/$defs/placement"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean"]
          }
        }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "properties": {
        "zone": {
          "type": "string",
          "enum": ["track_core", "street_edge", "concourse_center", "roofline", "plaza", "auto"]
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "connections": {
      "type": "object",
      "required": ["rail_tracks", "road_access", "pedestrian_entries"],
      "properties": {
        "rail_tracks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "road_access": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "pedestrian_entries": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16
        },
        "transit_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["train", "metro", "tram", "bus", "taxi", "pedestrian"]
          },
          "uniqueItems": true
        },
        "road_access_type": {
          "type": "string",
          "enum": ["none", "local_street", "arterial", "terminal_loop"]
        },
        "pedestrian_network": {
          "type": "string",
          "enum": ["street_entries", "elevated_walkways", "underground_passage", "mixed"]
        }
      },
      "additionalProperties": false
    },
    "decor": {
      "type": "object",
      "required": ["sign_language", "color_palette"],
      "properties": {
        "sign_language": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "items": {
            "type": "string",
            "pattern": "^[a-z]{2}(-[A-Z]{2})?$"
          },
          "uniqueItems": true
        },
        "color_palette": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          },
          "uniqueItems": true
        },
        "signage_style": {
          "type": "string",
          "enum": ["neutral", "mtr_inspired", "airport_wayfinding", "municipal"]
        },
        "logo_policy": {
          "type": "string",
          "enum": ["none", "fictional_only", "user_provided"]
        },
        "surface_patterns": {
          "type": "array",
          "maxItems": 6,
          "items": {
            "type": "string",
            "enum": ["platform_stripes", "glass_mullions", "tile_grid", "roof_ribs", "painted_panels"]
          }
        }
      },
      "additionalProperties": false
    },
    "preview_hints": {
      "type": "object",
      "properties": {
        "camera_angle": {
          "type": "string",
          "enum": ["front", "isometric", "top_down", "platform_level"]
        },
        "show_connection_points": {
          "type": "boolean"
        },
        "show_module_labels": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "properties": {
        "requires_new_save": {
          "type": "boolean"
        },
        "requires_asset_editor_import": {
          "type": "boolean"
        },
        "known_limits": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 200
          }
        }
      },
      "additionalProperties": false
    },
    "runtime_constraints": {
      "type": "object",
      "required": ["template_only", "requires_base_mod", "base_mod_min_version"],
      "properties": {
        "template_only": {
          "type": "boolean",
          "const": true
        },
        "requires_base_mod": {
          "type": "boolean",
          "const": true
        },
        "base_mod_min_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "allowed_runtime": {
          "type": "string",
          "enum": ["cs2_base_mod"]
        },
        "max_module_instances": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        }
      },
      "additionalProperties": false
    }
  }
}
